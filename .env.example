# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk Auth ─────────────────────────────────────────────────────────────────
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── External API Keys ──────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
POLYGON_API_KEY=your-polygon-key
FINNHUB_API_KEY=your-finnhub-key           # Free at finnhub.io
NEWS_API_KEY=your-newsapi-key              # Free at newsapi.org
GNEWS_API_KEY=your-gnews-key
MARKETAUX_API_KEY=your-marketaux-key
GEMINI_API_KEY=your-gemini-key
HUGGINGFACE_API_KEY=your-huggingface-key
HUGGINGFACE_MARKETS_MODEL=Qwen/Qwen2.5-7B-Instruct
FMP_API_KEY=your-fmp-key                   # financialmodelingprep.com

# ── Broker OAuth ───────────────────────────────────────────────────────────────
ZERODHA_API_KEY=your-zerodha-api-key
ZERODHA_API_SECRET=your-zerodha-api-secret

UPSTOX_CLIENT_ID=your-upstox-client-id
UPSTOX_CLIENT_SECRET=your-upstox-client-secret
UPSTOX_REDIRECT_URI=https://localhost:8000/api/v1/broker/upstox/callback

ANGEL_ONE_API_KEY=your-angel-one-api-key
ANGEL_ONE_CLIENT_ID=your-angel-one-client-id

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_TOKEN_ENCRYPTION_KEY=your-32-byte-fernet-key-base64

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://localhost:3000"]
FRONTEND_APP_URL=https://localhost:3000

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Frontend (Next.js .env.local) ──────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_API_URL=https://localhost:8000/api/v1
NEXT_PUBLIC_ZERODHA_API_KEY=your-zerodha-api-key
